<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.collections.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import java.lang.String?>
<AnchorPane prefHeight="800.0" prefWidth="900.0" styleClass="anchor-pane"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.zhaw.it.pm3.tournamentgenerator.controller.CreateNewTournamentUIController"
            stylesheets="/style.css">

    <ScrollPane fitToWidth="true" fitToHeight="true"
                AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
                AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"
                styleClass="scroll-pane">

        <VBox alignment="TOP_CENTER" spacing="25" style="-fx-padding: 40;">
            <!-- Title -->
            <Label text="Create New Tournament" styleClass="label-title"/>

            <!-- Game Selection -->
            <VBox spacing="10">
                <Label text="Game" styleClass="label-subtitle"/>
                <ComboBox fx:id="gameComboBox" promptText="Select Game" styleClass="combo-box">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="Football" />
                        </FXCollections>
                    </items>
                </ComboBox>
            </VBox>

            <!-- Tournament Type Selection -->
            <VBox spacing="10">
                <Label text="Tournament Type" styleClass="label-subtitle"/>
                <ComboBox fx:id="tournamentTypeComboBox" promptText="Select Type" styleClass="combo-box">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="Standard" />
                        </FXCollections>
                    </items>
                </ComboBox>
            </VBox>

            <!-- Number of Teams -->
            <VBox spacing="10">
                <Label text="Number of Teams" styleClass="label-subtitle"/>
                <TextField fx:id="teamCountTextField" promptText="e.g., 2, 4, 8..." styleClass="text-field"/>
            </VBox>

            <!-- Tournament Creator -->
            <VBox spacing="10">
                <Label text="Tournament Creator" styleClass="label-subtitle"/>
                <Label fx:id="creatorIdLabel" styleClass="label-subtitle" style="-fx-background-color: transparent; -fx-border-color: #434C5E; -fx-padding: 6;"/>
            </VBox>

            <!-- Tournament Name -->
            <VBox spacing="10">
                <Label text="Tournament Name" styleClass="label-subtitle"/>
                <TextField fx:id="tournamentNameTextField" promptText="e.g., 2nd Division U23" styleClass="text-field"/>
            </VBox>

            <!-- Buttons -->
            <HBox alignment="CENTER" spacing="20" style="-fx-padding: 20 0 0 0;">
                <Button fx:id="addPlayerButton" text="Add Players" onAction="#switchToPlayerAssignment" styleClass="button button-primary"/>
                <Button fx:id="confirmButton" text="Confirm" onAction="#showTournamentTree" styleClass="button button-primary" style="-fx-background-color: #A3BE8C;"/>
                <Button fx:id="backButton" text="Back to Main Menu" onAction="#backToMainMenu" styleClass="button button-danger" style="-fx-background-color: #D08770;"/>
            </HBox>

            <TextArea fx:id="summaryTextArea" editable="false" wrapText="true" styleClass="summary-text-area"/>
        </VBox>
    </ScrollPane>
</AnchorPane>
