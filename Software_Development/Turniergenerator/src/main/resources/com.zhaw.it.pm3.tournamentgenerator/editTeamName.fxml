<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15" xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.zhaw.it.pm3.tournamentgenerator.controller.EditTeamNameController"
      alignment="CENTER" stylesheets="/style.css" styleClass="v-box">

    <Label text="Edit Team Name" styleClass="label-title"/>

    <TextField fx:id="teamNameField" promptText="Enter new team name" styleClass="text-field"/>

    <HBox spacing="10" alignment="CENTER" styleClass="h-box">
        <Button text="Save" onAction="#saveTeamName" styleClass="button button-primary"/>
        <Button text="Cancel" onAction="#cancel" styleClass="button button-secondary"/>
    </HBox>
</VBox>
